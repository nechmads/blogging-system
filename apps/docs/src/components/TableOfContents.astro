---
interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav
    class="hidden xl:block sticky top-24 w-56 shrink-0 self-start"
    aria-label="Table of contents"
  >
    <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
      On this page
    </h4>
    <ul class="space-y-1.5 text-sm">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-primary)]',
              heading.depth === 3 && 'pl-3',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
