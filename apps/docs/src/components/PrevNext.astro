---
import { findPrevNext } from '../lib/navigation';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const { prev, next } = findPrevNext(currentSlug);
---

{(prev || next) && (
  <nav class="mt-12 flex items-stretch gap-4 border-t border-[var(--color-border-default)] pt-6" aria-label="Page navigation">
    {prev ? (
      <a
        href={`/${prev.slug}`}
        class="flex flex-1 flex-col rounded-lg border border-[var(--color-border-default)] px-4 py-3 text-sm transition-colors hover:border-[var(--color-accent)] hover:bg-[var(--color-accent-subtle)]"
      >
        <span class="text-xs text-[var(--color-text-muted)]">Previous</span>
        <span class="font-medium text-[var(--color-text-primary)]">{prev.title}</span>
      </a>
    ) : (
      <div class="flex-1" />
    )}
    {next ? (
      <a
        href={`/${next.slug}`}
        class="flex flex-1 flex-col items-end rounded-lg border border-[var(--color-border-default)] px-4 py-3 text-sm transition-colors hover:border-[var(--color-accent)] hover:bg-[var(--color-accent-subtle)]"
      >
        <span class="text-xs text-[var(--color-text-muted)]">Next</span>
        <span class="font-medium text-[var(--color-text-primary)]">{next.title}</span>
      </a>
    ) : (
      <div class="flex-1" />
    )}
  </nav>
)}
